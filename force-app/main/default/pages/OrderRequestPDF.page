<apex:page controller="OrderRequestPDFController" renderAs="pdf" showHeader="false" sidebar="false" standardStylesheets="false">
<head>
<style>
    body { font-family: Arial, sans-serif; color: #333; margin: 0; padding: 24px; font-size: 13px; }
    .header { background-color: #3d6b4f; color: white; padding: 20px 24px; margin-bottom: 24px; }
    .header h1 { margin: 0; font-size: 22px; letter-spacing: 1px; }
    .header .subtitle { margin: 4px 0 0 0; font-size: 11px; opacity: 0.85; }
    .header .order-num { float: right; font-size: 14px; font-weight: bold; margin-top: 4px; }
    .section-title { background-color: #e8f2ec; color: #3d6b4f; padding: 6px 10px; font-weight: bold;
                     border-left: 4px solid #3d6b4f; margin: 20px 0 10px 0; font-size: 12px; }
    table.info { width: 100%; border-collapse: collapse; margin-bottom: 8px; }
    table.info td { padding: 5px 8px; border-bottom: 1px solid #f0f0f0; vertical-align: top; }
    table.info td.label { font-weight: bold; color: #666; width: 28%; font-size: 11px; }
    table.items { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    table.items th { background-color: #3d6b4f; color: white; padding: 7px 8px; text-align: left; font-size: 11px; }
    table.items th.right { text-align: right; }
    table.items td { padding: 7px 8px; border-bottom: 1px solid #eee; font-size: 11px; vertical-align: middle; }
    table.items td.right { text-align: right; }
    table.items tr.even { background-color: #f8faf8; }
    table.items tr.total { background-color: #e8f2ec; font-weight: bold; }
    .deposit-note { border: 1px solid #c8e6c9; background-color: #f1f8f3; padding: 10px 14px;
                    margin-top: 10px; font-size: 10px; color: #555; }
    .deposit-note strong { color: #3d6b4f; }
    .footer { margin-top: 28px; text-align: center; font-size: 9px; color: #aaa;
              border-top: 1px solid #ddd; padding-top: 10px; }
    .clearfix:after { content: ""; display: table; clear: both; }
</style>
</head>
<body>
    <div class="header clearfix">
        <span class="order-num"># <apex:outputText value="{!orderRequest.Name}"/></span>
        <h1>Alma Natural Cosmetics</h1>
        <p class="subtitle">Order Confirmation</p>
    </div>

    <div class="section-title">Order Details</div>
    <table class="info">
        <tr>
            <td class="label">Customer</td>
            <td><apex:outputText value="{!orderRequest.Contact__r.Name}"/></td>
            <td class="label">Order Date</td>
            <td><apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!orderRequest.Order_Date__c}"/></apex:outputText></td>
        </tr>
        <tr>
            <td class="label">Status</td>
            <td><apex:outputText value="{!orderRequest.Status__c}"/></td>
            <td class="label">Payment Method</td>
            <td><apex:outputText value="{!orderRequest.Payment_Method__c}"/></td>
        </tr>
        <apex:outputPanel rendered="{!NOT(ISBLANK(orderRequest.Notes__c))}">
        <tr>
            <td class="label">Notes</td>
            <td colspan="3"><apex:outputText value="{!orderRequest.Notes__c}"/></td>
        </tr>
        </apex:outputPanel>
    </table>

    <div class="section-title">Order Items</div>
    <table class="items">
        <thead>
            <tr>
                <th>Product</th>
                <th class="right">Qty</th>
                <th class="right">Unit Price</th>
                <th>Container Deposit</th>
                <th class="right">Deposit</th>
                <th class="right">Line Total</th>
            </tr>
        </thead>
        <tbody>
            <apex:repeat value="{!lineItems}" var="li">
            <tr class="{!li.rowClass}">
                <td><apex:outputText value="{!li.productName}"/></td>
                <td class="right"><apex:outputText value="{!li.item.Quantity__c}"/></td>
                <td class="right"><apex:outputText value="{!li.formattedUnitPrice}"/></td>
                <td><apex:outputText value="{!IF(li.item.Deposit_Container__c, 'Yes', 'No')}"/></td>
                <td class="right"><apex:outputText value="{!li.formattedDepositPrice}"/></td>
                <td class="right"><apex:outputText value="{!li.formattedLineTotal}"/></td>
            </tr>
            </apex:repeat>
            <tr class="total">
                <td colspan="5">Total Amount</td>
                <td class="right"><apex:outputText value="{!formattedTotal}"/></td>
            </tr>
        </tbody>
    </table>

    <div class="deposit-note">
        <strong>Container Deposit Program:</strong>
        Alma Natural Cosmetics encourages customers to return empty containers.
        Each returned container earns a discount on your next order.
        Thank you for helping us reduce waste!
    </div>

    <div class="footer">
        Alma Natural Cosmetics &bull; Handmade with love &bull;
        Generated on <apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!TODAY()}"/></apex:outputText>
    </div>
</body>
</apex:page>