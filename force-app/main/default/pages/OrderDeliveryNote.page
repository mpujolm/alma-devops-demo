<apex:page controller="OrderDeliveryNoteController" renderAs="pdf" applyHtmlTag="false" showHeader="false" sidebar="false">
<html>
<head>
<style type="text/css">
    body {
        font-family: Arial, sans-serif;
        font-size: 11pt;
        color: #333333;
        margin: 40px;
    }
    .header-block { margin-bottom: 6px; }
    h1 { font-size: 22pt; color: #2c5f2e; margin: 0 0 2px 0; }
    h2 { font-size: 13pt; color: #666666; margin: 0 0 16px 0; font-weight: normal; }
    hr { border: none; border-top: 2px solid #2c5f2e; margin-bottom: 20px; }
    .meta-table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
    .meta-table td { border: none; padding: 3px 6px; vertical-align: top; font-size: 10.5pt; }
    .meta-label { font-weight: bold; width: 130px; color: #444444; }
    .items-table { width: 100%; border-collapse: collapse; }
    .items-table thead tr { background-color: #2c5f2e; }
    .items-table th {
        color: #ffffff;
        padding: 8px 6px;
        text-align: left;
        font-size: 10pt;
        font-weight: bold;
    }
    .items-table th.num { text-align: right; }
    .items-table td { padding: 6px; border-bottom: 1px solid #dddddd; font-size: 10pt; }
    .items-table td.num { text-align: right; }
    .items-table tr.alt td { background-color: #f5f5f5; }
    .total-row td {
        font-weight: bold;
        border-top: 2px solid #2c5f2e;
        border-bottom: none;
        padding-top: 8px;
        font-size: 10.5pt;
    }
    .footer {
        margin-top: 36px;
        font-size: 8.5pt;
        color: #aaaaaa;
        text-align: center;
        border-top: 1px solid #dddddd;
        padding-top: 8px;
    }
</style>
</head>
<body>
    <div class="header-block">
        <h1>Alma Natural Cosmetics</h1>
        <h2>Delivery Note</h2>
    </div>
    <hr/>

    <table class="meta-table">
        <tr>
            <td class="meta-label">Order Number:</td>
            <td><apex:outputText value="{!order.Name}"/></td>
            <td class="meta-label">Customer:</td>
            <td><apex:outputText value="{!order.Contact__r.Name}"/></td>
        </tr>
        <tr>
            <td class="meta-label">Order Date:</td>
            <td>
                <apex:outputText value="{0,date,dd/MM/yyyy}">
                    <apex:param value="{!order.Order_Date__c}"/>
                </apex:outputText>
            </td>
            <td class="meta-label">Payment Method:</td>
            <td><apex:outputText value="{!order.Payment_Method__c}"/></td>
        </tr>
        <tr>
            <td class="meta-label">Status:</td>
            <td><apex:outputText value="{!order.Status__c}"/></td>
            <td class="meta-label">Generated:</td>
            <td>
                <apex:outputText value="{0,date,dd/MM/yyyy}">
                    <apex:param value="{!generatedDate}"/>
                </apex:outputText>
            </td>
        </tr>
    </table>

    <table class="items-table">
        <thead>
            <tr>
                <th>Product</th>
                <th class="num">Qty</th>
                <th class="num">Unit Price</th>
                <th>Container Deposit</th>
                <th class="num">Deposit Price</th>
                <th class="num">Line Total</th>
            </tr>
        </thead>
        <tbody>
            <apex:repeat value="{!lineItems}" var="item">
                <tr>
                    <td><apex:outputText value="{!item.Product__r.Name}"/></td>
                    <td class="num">
                        <apex:outputText value="{0,number,#,##0}">
                            <apex:param value="{!item.Quantity__c}"/>
                        </apex:outputText>
                    </td>
                    <td class="num">
                        <apex:outputText value="{0,number,#,##0.00} &#8364;">
                            <apex:param value="{!item.Customer_Price__c}"/>
                        </apex:outputText>
                    </td>
                    <td>
                        <apex:outputText value="{!IF(item.Deposit_Container__c, 'Yes', 'No')}"/>
                    </td>
                    <td class="num">
                        <apex:outputText value="{0,number,#,##0.00} &#8364;">
                            <apex:param value="{!item.Deposit_Price__c}"/>
                        </apex:outputText>
                    </td>
                    <td class="num">
                        <apex:outputText value="{0,number,#,##0.00} &#8364;">
                            <apex:param value="{!item.Line_Total__c}"/>
                        </apex:outputText>
                    </td>
                </tr>
            </apex:repeat>
            <tr class="total-row">
                <td colspan="5" style="text-align:right;">TOTAL</td>
                <td class="num">
                    <apex:outputText value="{0,number,#,##0.00} &#8364;">
                        <apex:param value="{!order.Total_Amount_Ana__c}"/>
                    </apex:outputText>
                </td>
            </tr>
        </tbody>
    </table>

    <div class="footer">
        Alma Natural Cosmetics &#183; Handmade with care
    </div>
</body>
</html>
</apex:page>
