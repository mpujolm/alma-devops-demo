<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <description>Before Save flow on Order Request Line Item. Copies Unit Price and Deposit Price from the selected Product when the record is created or updated. Prices are locked at the time of save.</description>
    <environments>Default</environments>
    <interviewLabel>Set Order Line Item Prices from Product {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Set Order Line Item Prices from Product</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_Prices</targetReference>
        </connector>
        <filterLogic>1</filterLogic>
        <filters>
            <field>Product__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>OrderRequestLineItem__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <assignments>
        <name>Set_Prices</name>
        <label>Set Prices</label>
        <locationX>50</locationX>
        <locationY>120</locationY>
        <assignmentItems>
            <assignToReference>$Record.Unit_Price__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Product__r.Price__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.Deposit_Price__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Product__r.Deposit_Price__c</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <status>Active</status>
</Flow>
