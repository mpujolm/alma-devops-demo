<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Notify_Admin_Case_Error</name>
        <label>Notify Admin: Case Creation Failed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>emailAddresses</name>
            <value>
                <elementReference>AdminEmail</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailSubject</name>
            <value>
                <stringValue>[Alma Flow] Error al crear Case - Low Stock Alert</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailBody</name>
            <value>
                <elementReference>EmailBody_CaseCreateError</elementReference>
            </value>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
    </actionCalls>
    <actionCalls>
        <name>Notify_Admin_User_Not_Found</name>
        <label>Notify Admin: User Not Found</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>emailAddresses</name>
            <value>
                <elementReference>AdminEmail</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailSubject</name>
            <value>
                <stringValue>[Alma Flow] Error: Usuario no encontrado - Low Stock Alert</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailBody</name>
            <value>
                <elementReference>EmailBody_UserNotFound</elementReference>
            </value>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
    </actionCalls>
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>User_Found</name>
        <label>User Found?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Notify_Admin_User_Not_Found</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No (User Not Found)</defaultConnectorLabel>
        <rules>
            <name>Yes_User_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_AssignedUser.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_LowStockCase</targetReference>
            </connector>
            <label>Yes (User Found)</label>
        </rules>
    </decisions>
    <description>Creates a high priority Case assigned to Ana Perez when a Product Stock__c drops below 10 units for the first time (threshold crossing only). If stock is negative, the Case warns that the stock value may be incorrect and needs review.</description>
    <environments>Default</environments>
    <formulas>
        <name>AdminEmail</name>
        <dataType>String</dataType>
        <expression>{!$User.Email}</expression>
    </formulas>
    <formulas>
        <name>CaseDescription</name>
        <dataType>String</dataType>
        <expression>IF(
  {!$Record.Stock__c} &lt; 0,
  &quot;ATENCIÓN: El producto &quot; &amp; {!$Record.Name} &amp; &quot; tiene stock NEGATIVO (&quot; &amp; TEXT({!$Record.Stock__c}) &amp; &quot; unidades). El stock puede estar mal, hay que revisarlo.&quot;,
  &quot;El producto &quot; &amp; {!$Record.Name} &amp; &quot; tiene &quot; &amp; TEXT({!$Record.Stock__c}) &amp; &quot; unidades en stock. Se requiere reposición urgente.&quot;
)</expression>
    </formulas>
    <formulas>
        <name>CaseSubject</name>
        <dataType>String</dataType>
        <expression>IF(
  {!$Record.Stock__c} &lt; 0,
  &quot;Stock Negativo - Revisar: &quot; &amp; {!$Record.Name},
  &quot;Low Stock Alert: &quot; &amp; {!$Record.Name}
)</expression>
    </formulas>
    <formulas>
        <name>EmailBody_CaseCreateError</name>
        <dataType>String</dataType>
        <expression>&quot;El flow &apos;Low Stock Alert&apos; no pudo crear el Case para el producto &apos;&quot; &amp; {!$Record.Name} &amp; &quot;&apos;. Error: &quot; &amp; {!$Flow.FaultMessage}</expression>
    </formulas>
    <formulas>
        <name>EmailBody_UserNotFound</name>
        <dataType>String</dataType>
        <expression>&quot;El flow &apos;Low Stock Alert&apos; se ejecutó para el producto &apos;&quot; &amp; {!$Record.Name} &amp; &quot;&apos; pero no encontró el usuario &apos;ana.perez@alma-natural-cosmetics.dev&apos;. Verifica que el username en el flow es correcto.&quot;</expression>
    </formulas>
    <interviewLabel>Alma Product Low Stock Alert {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Alma - Product Low Stock Alert</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_LowStockCase</name>
        <label>Create Low Stock Case</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Notify_Admin_Case_Error</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Description</field>
            <value>
                <elementReference>CaseDescription</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Origin</field>
            <value>
                <stringValue>Internal</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OwnerId</field>
            <value>
                <elementReference>Get_AssignedUser.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Priority</field>
            <value>
                <stringValue>High</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>New</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Subject</field>
            <value>
                <elementReference>CaseSubject</elementReference>
            </value>
        </inputAssignments>
        <object>Case</object>
    </recordCreates>
    <recordLookups>
        <name>Get_AssignedUser</name>
        <label>Get Assigned User</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>User_Found</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Username</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>ana.perez@alma-natural-cosmetics.dev</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>User</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_AssignedUser</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Stock__c</field>
            <operator>LessThan</operator>
            <value>
                <numberValue>10.0</numberValue>
            </value>
        </filters>
        <object>Product2</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
